# Copie ce fichier en .env et remplis les valeurs

# Discord bot token
DISCORD_TOKEN=your_discord_bot_token_here

# ComfyUI (image/video generation) — depuis Docker, utiliser host.docker.internal
COMFYUI_HOST=host.docker.internal
COMFYUI_PORT=8188

# Ollama (LLM local) — depuis Docker, utiliser host.docker.internal
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434
OLLAMA_MODEL=augure-mj
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Timeouts en secondes
MJ_TIMEOUT=600
NPC_TIMEOUT=60

# Suno — génération musicale (sunoapi.org)
SUNO_API_KEY=your_suno_api_key_here
SUNO_BASE_URL=https://api.sunoapi.org

# IDs Discord des admins (séparés par virgule)
ADMIN_USER_IDS=your_discord_user_id_here

# Intervalles des tâches de fond en minutes (0 = désactivé)
WATCHDOG_INTERVAL=1
MAINTENANCE_INTERVAL=60
